<script>
/* ============= STATE & PERSISTENCE ============= */
const KEY = "bull_bear_club_v1";
const defaultState = {
  welcomed: false,
  user: { name: "", project: "" },
  president: {
    name: "Raiden",
    emails: [
      "raiden.borromeo@universityneighborhoodhs.org",
      "raidenb0510@gmail.com"
    ]
  },
  vicePresident: {
    name: "Vice President",
    emails: []
  },
  collaborators: [],
  investments: [],
  meetings: [],
  goals: [],
  tasks: [
    { title: "Set up a paper-trading account", role: "Any", done: false },
    { title: "Pick your role on the Roles tab", role: "Any", done: false },
    { title: "Research your first stock pitch", role: "Researcher", done: false },
    { title: "Post a weekly market brief", role: "Market Analyst", done: false },
  ],
  benchmark: { start: 10000, spyStart: 0, spyCurrent: 0 },
  questions: [],
  members: [],
  announcements: [],
};

function loadState() {
  try {
    const raw = localStorage.getItem(KEY);
    if (!raw) return { ...defaultState };
    return { ...defaultState, ...JSON.parse(raw) };
  } catch { return { ...defaultState }; }
}
let state = loadState();

function saveState() {
  localStorage.setItem(KEY, JSON.stringify(state));
  flashSaved();
}
function flashSaved() {
  const b = document.getElementById("saveBadge");
  b.classList.add("show");
  clearTimeout(window._savet);
  window._savet = setTimeout(() => b.classList.remove("show"), 1000);
}

/* ============= WELCOME MODAL ============= */
function addEmail() {
  const list = document.getElementById("emailList");
  const row = document.createElement("div");
  row.className = "email-row";
  row.innerHTML = `<input type="email" placeholder="teammate@school.edu" />
    <button class="icon-btn minus" onclick="removeEmail(this)">−</button>`;
  list.appendChild(row);
}
function removeEmail(btn) {
  const rows = document.querySelectorAll("#emailList .email-row");
  if (rows.length > 1) btn.parentElement.remove();
}
function saveWelcome() {
  state.user.name = document.getElementById("welcomeName").value.trim();
  state.user.project = document.getElementById("welcomeProject").value.trim();
  const emails = [...document.querySelectorAll("#emailList input")].map(i => i.value.trim()).filter(Boolean);
  state.collaborators = emails;
  // Create member entries
  emails.forEach(e => {
    if (!state.members.find(m => m.email === e)) {
      state.members.push({ name: e.split("@")[0], email: e, role: "Researcher", fund: 0 });
    }
  });
  state.welcomed = true;
  saveState();
  closeWelcome();
  renderAll();
}
function skipWelcome() {
  state.welcomed = true;
  saveState();
  closeWelcome();
}
function closeWelcome() {
  document.getElementById("welcomeModal").style.display = "none";
}
function openWelcome() {
  document.getElementById("welcomeModal").style.display = "flex";
}

/* ============= NAVIGATION ============= */
function nav(page) {
  document.querySelectorAll(".nav-item").forEach(n => n.classList.remove("active"));
  document.querySelectorAll(".page").forEach(p => p.classList.remove("active"));
  document.querySelector(`.nav-item[data-page="${page}"]`)?.classList.add("active");
  document.getElementById(page)?.classList.add("active");
  window.scrollTo({ top: 0, behavior: "smooth" });
}
document.querySelectorAll(".nav-item").forEach(n => {
  n.addEventListener("click", () => nav(n.dataset.page));
});

/* ============= INVESTMENTS ============= */
function toggleAddInvestment() {
  const f = document.getElementById("addInvestmentForm");
  f.style.display = f.style.display === "none" ? "block" : "none";
}
function addInvestment() {
  const ticker = document.getElementById("newTicker").value.trim().toUpperCase();
  if (!ticker) return alert("Ticker required");
  state.investments.push({
    id: Date.now(),
    ticker,
    name: document.getElementById("newName").value.trim(),
    shares: parseFloat(document.getElementById("newShares").value) || 0,
    buy: parseFloat(document.getElementById("newBuy").value) || 0,
    current: parseFloat(document.getElementById("newCurrent").value) || 0,
    date: document.getElementById("newDate").value,
  });
  ["newTicker","newName","newShares","newBuy","newCurrent","newDate"].forEach(i => document.getElementById(i).value = "");
  toggleAddInvestment();
  saveState();
  renderInvestments();
  renderDashboard();
}
function deleteInvestment(id) {
  if (!confirm("Delete this position?")) return;
  state.investments = state.investments.filter(i => i.id !== id);
  saveState();
  renderInvestments();
  renderDashboard();
}
function updateInvField(id, field, val) {
  const inv = state.investments.find(i => i.id === id);
  if (!inv) return;
  inv[field] = (field === "shares" || field === "buy" || field === "current") ? parseFloat(val) || 0 : val;
  saveState();
  renderInvestments();
  renderDashboard();
}
function renderInvestments() {
  const tbody = document.getElementById("invTable");
  if (!state.investments.length) {
    tbody.innerHTML = `<tr><td colspan="8" style="text-align:center; color:var(--muted);">No positions yet. Add your first trade above.</td></tr>`;
  } else {
    tbody.innerHTML = state.investments.map(i => {
      const value = i.shares * i.current;
      const cost = i.shares * i.buy;
      const ret = cost ? ((value - cost) / cost) * 100 : 0;
      const retClass = ret >= 0 ? "stat-up" : "stat-down";
      return `<tr>
        <td><strong>${i.ticker}</strong></td>
        <td>${i.name}</td>
        <td><input type="number" step="0.01" value="${i.shares}" onchange="updateInvField(${i.id},'shares',this.value)" style="width:80px;"/></td>
        <td><input type="number" step="0.01" value="${i.buy}" onchange="updateInvField(${i.id},'buy',this.value)" style="width:90px;"/></td>
        <td><input type="number" step="0.01" value="${i.current}" onchange="updateInvField(${i.id},'current',this.value)" style="width:90px;"/></td>
        <td>$${value.toFixed(2)}</td>
        <td class="${retClass}">${ret.toFixed(2)}%</td>
        <td><button class="btn btn-danger btn-sm" onclick="deleteInvestment(${i.id})">✕</button></td>
      </tr>`;
    }).join("");
  }
  const totalCost = state.investments.reduce((s,i)=>s+i.shares*i.buy,0);
  const totalVal = state.investments.reduce((s,i)=>s+i.shares*i.current,0);
  const dollarRet = totalVal - totalCost;
  const pctRet = totalCost ? (dollarRet/totalCost)*100 : 0;
  document.getElementById("invTotalCost").textContent = "$" + totalCost.toFixed(2);
  document.getElementById("invCurrent").textContent = "$" + totalVal.toFixed(2);
  document.getElementById("invReturn").textContent = pctRet.toFixed(2) + "%";
  document.getElementById("invReturnDollar").textContent = (dollarRet>=0?"+":"") + "$" + dollarRet.toFixed(2);

  // Benchmark
  document.getElementById("startCapital").value = state.benchmark.start || "";
  document.getElementById("spyStart").value = state.benchmark.spyStart || "";
  document.getElementById("spyCurrent").value = state.benchmark.spyCurrent || "";
  renderBenchmark(pctRet);
}
function renderBenchmark(clubPct) {
  const b = state.benchmark;
  const el = document.getElementById("spyResult");
  if (!b.spyStart || !b.spyCurrent) {
    el.innerHTML = `<span class="bulb">💡</span> Enter benchmark values above to see how your club compares.`;
    return;
  }
  const spyRet = ((b.spyCurrent - b.spyStart)/b.spyStart)*100;
  const diff = clubPct - spyRet;
  const winning = diff >= 0;
  el.innerHTML = `<span class="bulb">${winning?"🏆":"📉"}</span>
    Your club is <strong class="${winning?'stat-up':'stat-down'}">${winning?"beating":"trailing"}</strong> the S&P 500 by <strong>${Math.abs(diff).toFixed(2)}%</strong>.
    <br/><span style="color:var(--muted);font-size:13px;">Club return: ${clubPct.toFixed(2)}% · S&P 500: ${spyRet.toFixed(2)}%</span>`;
}
document.getElementById("startCapital")?.addEventListener("change", e => { state.benchmark.start = parseFloat(e.target.value) || 0; saveState(); });
document.getElementById("spyStart")?.addEventListener("change", e => { state.benchmark.spyStart = parseFloat(e.target.value) || 0; saveState(); renderInvestments(); });
document.getElementById("spyCurrent")?.addEventListener("change", e => { state.benchmark.spyCurrent = parseFloat(e.target.value) || 0; saveState(); renderInvestments(); });

/* ============= MEETINGS ============= */
function toggleMeetingForm() {
  const f = document.getElementById("meetingForm");
  f.style.display = f.style.display === "none" ? "block" : "none";
}
function addMeeting() {
  const title = document.getElementById("mTitle").value.trim();
  if (!title) return alert("Title required");
  state.meetings.unshift({
    id: Date.now(),
    title,
    date: document.getElementById("mDate").value || new Date().toISOString().split("T")[0],
    attendees: document.getElementById("mAttendees").value.split(",").map(s=>s.trim()).filter(Boolean),
    notes: document.getElementById("mNotes").value,
  });
  ["mTitle","mDate","mAttendees","mNotes"].forEach(i => document.getElementById(i).value = "");
  toggleMeetingForm();
  saveState();
  renderMeetings();
  renderDashboard();
}
function deleteMeeting(id) {
  if (!confirm("Delete this meeting?")) return;
  state.meetings = state.meetings.filter(m => m.id !== id);
  saveState();
  renderMeetings();
  renderDashboard();
}
function renderMeetings() {
  const list = document.getElementById("meetingsList");
  if (!state.meetings.length) {
    list.innerHTML = `<div class="card"><p style="color:var(--muted); text-align:center;">No meetings logged yet. Click "Log Meeting" to add your first.</p></div>`;
    return;
  }
  list.innerHTML = state.meetings.map(m => `
    <div class="meeting-card">
      <div class="meeting-date">${formatDate(m.date)}</div>
      <div class="meeting-title">${escapeHtml(m.title)}</div>
      <div class="meeting-attendees">${m.attendees.map(a=>`<span class="chip">${escapeHtml(a)}</span>`).join("")}</div>
      <div class="meeting-notes">${escapeHtml(m.notes)}</div>
      <button class="btn btn-danger btn-sm" style="margin-top:10px;" onclick="deleteMeeting(${m.id})">Delete</button>
    </div>
  `).join("");
}

/* ============= GOALS ============= */
function toggleGoalForm() {
  const f = document.getElementById("goalForm");
  f.style.display = f.style.display === "none" ? "block" : "none";
}
function addGoal() {
  const title = document.getElementById("gTitle").value.trim();
  if (!title) return alert("Goal required");
  state.goals.push({
    id: Date.now(), title,
    date: document.getElementById("gDate").value,
    details: document.getElementById("gDetails").value,
    done: false,
  });
  ["gTitle","gDate","gDetails"].forEach(i => document.getElementById(i).value = "");
  toggleGoalForm();
  saveState();
  renderGoals();
  renderDashboard();
}
function toggleGoal(id) {
  const g = state.goals.find(g => g.id === id);
  if (g) { g.done = !g.done; saveState(); renderGoals(); renderDashboard(); }
}
function deleteGoal(id) {
  state.goals = state.goals.filter(g => g.id !== id);
  saveState();
  renderGoals();
  renderDashboard();
}
function renderGoals() {
  const list = document.getElementById("goalsList");
  if (!state.goals.length) {
    list.innerHTML = `<p style="color:var(--muted);">No goals yet — add your first above.</p>`;
    return;
  }
  list.innerHTML = state.goals.map(g => `
    <div class="goal-item ${g.done ? 'done' : ''}">
      <div class="checkbox ${g.done?'checked':''}" onclick="toggleGoal(${g.id})"></div>
      <div style="flex:1;">
        <div class="label-text" style="font-weight:600;">${escapeHtml(g.title)}</div>
        ${g.date ? `<div style="font-size:12px; color:var(--muted);">Target: ${formatDate(g.date)}</div>` : ""}
        ${g.details ? `<div style="font-size:13px; color:var(--text); margin-top:4px;">${escapeHtml(g.details)}</div>` : ""}
      </div>
      <button class="btn btn-ghost btn-sm" onclick="deleteGoal(${g.id})">✕</button>
    </div>
  `).join("");
}

/* ============= TASKS ============= */
function toggleTaskForm() {
  const f = document.getElementById("taskForm");
  f.style.display = f.style.display === "none" ? "block" : "none";
}
function addTask() {
  const title = document.getElementById("tTitle").value.trim();
  if (!title) return alert("Task required");
  state.tasks.push({
    id: Date.now(),
    title,
    role: document.getElementById("tRole").value,
    done: false,
  });
  document.getElementById("tTitle").value = "";
  toggleTaskForm();
  saveState();
  renderTasks();
}
function toggleTask(id) {
  const t = state.tasks.find(t => t.id === id);
  if (t) { t.done = !t.done; saveState(); renderTasks(); renderDashboard(); }
}
function deleteTask(id) {
  state.tasks = state.tasks.filter(t => t.id !== id);
  saveState();
  renderTasks();
}
function renderTasks() {
  const list = document.getElementById("tasksList");
  if (!state.tasks.length) {
    list.innerHTML = `<p style="color:var(--muted);">No tasks yet — add one.</p>`;
  } else {
    // Assign ids to pre-built tasks if missing
    state.tasks.forEach(t => { if (!t.id) t.id = Date.now() + Math.random(); });
    list.innerHTML = state.tasks.map(t => `
      <div class="task-item ${t.done ? 'done' : ''}">
        <div class="checkbox ${t.done?'checked':''}" onclick="toggleTask(${t.id})"></div>
        <div style="flex:1;">
          <div class="label-text" style="font-weight:600;">${escapeHtml(t.title)}</div>
          <div style="font-size:12px; color:var(--muted); margin-top:2px;"><span class="chip chip-accent">${escapeHtml(t.role)}</span></div>
        </div>
        <button class="btn btn-ghost btn-sm" onclick="deleteTask(${t.id})">✕</button>
      </div>
    `).join("");
  }

  // Smart prompts
  const doneCount = state.tasks.filter(t => t.done).length;
  const total = state.tasks.length;
  const prompts = document.getElementById("taskPrompts");
  let promptHtml = "";
  if (total > 0 && doneCount === total) {
    promptHtml = `<div class="smart-prompt"><span class="bulb">🎉</span> You've cleared your task list! Great hustle. Add new ones or check in with the President for the next focus.</div>`;
  } else if (doneCount >= 4) {
    promptHtml = `<div class="smart-prompt"><span class="bulb">💡</span> Now that you have ${doneCount} tasks checked off, work with the <strong>Market Analyst</strong> to build a weekly sector brief, and pair with the <strong>Treasurer</strong> to update portfolio returns.</div>`;
  } else if (doneCount >= 2) {
    promptHtml = `<div class="smart-prompt"><span class="bulb">💡</span> Nice momentum — ${doneCount} done! Next, pair with the <strong>Researcher</strong> to finalize your next stock pitch.</div>`;
  } else if (doneCount === 1) {
    promptHtml = `<div class="smart-prompt"><span class="bulb">🚀</span> First one down! Tip: check in with the <strong>Secretary</strong> to make sure your work is logged in the next meeting notes.</div>`;
  }
  prompts.innerHTML = promptHtml;
}

/* ============= MEMBERS / ROLES ============= */
function toggleMemberForm() {
  const f = document.getElementById("memberForm");
  f.style.display = f.style.display === "none" ? "block" : "none";
}
function addMember() {
  const name = document.getElementById("memName").value.trim();
  if (!name) return alert("Name required");
