/* ============= QUESTIONS ============= */
function askQuestion() {
  const name = document.getElementById("qName").value.trim() || "Anonymous";
  const text = document.getElementById("qText").value.trim();
  if (!text) return alert("Type your question first");
  state.questions.unshift({
    id: Date.now(),
    name, text, answer: "",
    createdAt: new Date().toISOString(),
  });
  document.getElementById("qName").value = "";
  document.getElementById("qText").value = "";
  saveState();
  renderQuestions();
  renderPresident();
}
function answerQuestion(id, text) {
  const q = state.questions.find(q => q.id === id);
  if (q) {
    q.answer = text;
    if (activeLeader === "vp" && state.vicePresident && state.vicePresident.name) {
      q.answeredBy = state.vicePresident.name;
    } else if (activeLeader === "president" && state.president && state.president.name) {
      q.answeredBy = state.president.name;
    } else {
      q.answeredBy = activeLeader === "vp" ? "Vice President" : "President";
    }
    saveState();
    renderQuestions();
    renderPresident();
  }
}
function deleteQuestion(id) {
  state.questions = state.questions.filter(q => q.id !== id);
  saveState();
  renderQuestions();
  renderPresident();
}
function renderQuestions() {
  const list = document.getElementById("questionsList");
  const presName = (state.president && state.president.name) ? state.president.name : "the President";
  if (!state.questions.length) {
    list.innerHTML = `<p style="color:var(--muted);">No questions yet. Ask the first!</p>`;
    return;
  }
  list.innerHTML = state.questions.map(q => `
    <div class="q-card">
      <div class="q-text">${escapeHtml(q.text)}</div>
      <div class="q-meta">— ${escapeHtml(q.name)} · ${timeAgo(q.createdAt)}</div>
      ${q.answer
        ? `<div class="q-answer"><strong>${escapeHtml(q.answeredBy || presName)} (President):</strong> ${escapeHtml(q.answer)}</div>`
        : `<div style="font-size:12px; color:var(--muted);"><em>Awaiting ${escapeHtml(presName)}'s response...</em></div>`}
    </div>
