<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Bull & Bear Investing Club</title>
<style>
  :root {
    --navy: #0b1d3a;
    --navy-2: #122a52;
    --navy-3: #1b3a72;
    --accent: #1dbf73;
    --accent-dark: #14a25f;
    --gold: #f3b94d;
    --red: #e85c5c;
    --bg: #f4f6fb;
    --card: #ffffff;
    --text: #1a2236;
    --muted: #6b7591;
    --border: #e4e8f1;
    --shadow: 0 6px 24px rgba(13, 29, 58, 0.08);
    --shadow-lg: 0 16px 40px rgba(13, 29, 58, 0.18);
  }
  * { box-sizing: border-box; }
  html, body {
    margin: 0; padding: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
  }
  a { color: var(--accent-dark); text-decoration: none; }
  a:hover { text-decoration: underline; }
  button {
    font-family: inherit;
    cursor: pointer;
    border: none;
    outline: none;
  }

  /* ============= LAYOUT ============= */
  .app { display: flex; min-height: 100vh; }
  .sidebar {
    width: 260px;
    background: linear-gradient(180deg, var(--navy) 0%, var(--navy-2) 100%);
    color: #fff;
    padding: 24px 18px;
    position: sticky; top: 0; height: 100vh;
    overflow-y: auto;
  }
  .brand {
    display: flex; align-items: center; gap: 10px;
    font-weight: 800; font-size: 20px; letter-spacing: 0.3px;
    margin-bottom: 28px;
  }
  .brand .logo {
    width: 38px; height: 38px; border-radius: 10px;
    background: linear-gradient(135deg, var(--accent) 0%, #0fa866 100%);
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
  }
  .nav-section {
    font-size: 11px; text-transform: uppercase; letter-spacing: 1.2px;
    color: #8ea4c7; margin: 18px 8px 8px;
  }
  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px; border-radius: 10px;
    color: #d5e0f5; font-size: 14px; font-weight: 500;
    cursor: pointer; margin-bottom: 2px;
    transition: all 0.15s ease;
  }
  .nav-item:hover { background: rgba(255,255,255,0.06); color: #fff; }
  .nav-item.active {
    background: linear-gradient(90deg, rgba(29,191,115,0.2), rgba(29,191,115,0.05));
    color: #fff;
    box-shadow: inset 3px 0 0 var(--accent);
  }
  .nav-item .icon { font-size: 16px; width: 20px; text-align: center; }

  .main {
    flex: 1;
    padding: 32px 40px;
    max-width: calc(100vw - 260px);
  }
  .page-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 24px;
  }
  .page-title {
    font-size: 28px; font-weight: 800; letter-spacing: -0.5px;
    color: var(--navy);
  }
  .page-subtitle {
    color: var(--muted); font-size: 14px; margin-top: 4px;
  }

  /* ============= CARDS ============= */
  .card {
    background: var(--card);
    border-radius: 14px;
    padding: 20px;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
  }
  .card-title {
    font-size: 16px; font-weight: 700;
    margin: 0 0 12px 0; color: var(--navy);
  }
  .grid { display: grid; gap: 18px; }
  .grid-4 { grid-template-columns: repeat(4, 1fr); }
  .grid-3 { grid-template-columns: repeat(3, 1fr); }
  .grid-2 { grid-template-columns: repeat(2, 1fr); }
  @media (max-width: 1100px) { .grid-4 { grid-template-columns: repeat(2,1fr); } .grid-3 { grid-template-columns: repeat(2,1fr); } }
  @media (max-width: 700px)  { .grid-4, .grid-3, .grid-2 { grid-template-columns: 1fr; } }

  .stat-card {
    background: var(--card);
    border-radius: 14px;
    padding: 18px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
  }
  .stat-label {
    font-size: 12px; color: var(--muted);
    text-transform: uppercase; letter-spacing: 0.8px; font-weight: 600;
  }
  .stat-value {
    font-size: 26px; font-weight: 800; margin-top: 6px;
    color: var(--navy);
  }
  .stat-sub { font-size: 12px; color: var(--muted); margin-top: 4px; }
  .stat-up { color: var(--accent-dark); font-weight: 700; }
  .stat-down { color: var(--red); font-weight: 700; }

  /* ============= BUTTONS & INPUTS ============= */
  .btn {
    padding: 10px 16px;
    border-radius: 10px;
    font-size: 14px; font-weight: 600;
    transition: all 0.15s ease;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .btn-primary {
    background: var(--accent); color: #fff;
  }
  .btn-primary:hover { background: var(--accent-dark); transform: translateY(-1px); }
  .btn-secondary {
    background: #fff; color: var(--navy); border: 1px solid var(--border);
  }
  .btn-secondary:hover { background: #f6f9ff; }
  .btn-danger {
    background: #fff0f0; color: var(--red); border: 1px solid #ffd7d7;
  }
  .btn-danger:hover { background: #ffe0e0; }
  .btn-ghost {
    background: transparent; color: var(--muted);
  }
  .btn-sm { padding: 6px 10px; font-size: 12px; }

  input, textarea, select {
    width: 100%;
    padding: 10px 12px;
    border-radius: 8px;
    border: 1px solid var(--border);
    font-size: 14px;
    font-family: inherit;
    background: #fff;
    color: var(--text);
    outline: none;
    transition: border 0.15s;
  }
  input:focus, textarea:focus, select:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(29,191,115,0.12);
  }
  label {
    font-size: 12px; color: var(--muted); font-weight: 600;
    display: block; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px;
  }
  .form-row { display: flex; gap: 10px; margin-bottom: 12px; }
  .form-row > * { flex: 1; }

  /* ============= MODAL ============= */
  .modal-backdrop {
    position: fixed; inset: 0;
    background: rgba(11, 29, 58, 0.55);
    backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
    z-index: 100;
    padding: 20px;
  }
  .modal {
    background: #fff;
    border-radius: 16px;
    max-width: 560px; width: 100%;
    padding: 30px;
    box-shadow: var(--shadow-lg);
    max-height: 90vh; overflow-y: auto;
  }
  .modal-lg { max-width: 760px; }
  .modal h2 { margin: 0 0 6px; font-size: 22px; color: var(--navy); }
  .modal .subtitle { color: var(--muted); font-size: 14px; margin-bottom: 20px; }

  .email-row {
    display: flex; gap: 8px; margin-bottom: 8px; align-items: center;
  }
  .email-row input { flex: 1; }
  .icon-btn {
    width: 38px; height: 38px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    background: #f0f3fb; color: var(--navy);
    font-size: 18px; font-weight: 700;
  }
  .icon-btn:hover { background: #e4e8f1; }
  .icon-btn.minus { background: #fff0f0; color: var(--red); }
  .icon-btn.plus { background: rgba(29,191,115,0.12); color: var(--accent-dark); }

  /* ============= TABLES ============= */
  table {
    width: 100%; border-collapse: collapse;
    font-size: 14px;
  }
  th {
    text-align: left; padding: 12px; font-weight: 600;
    color: var(--muted); font-size: 12px; text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid var(--border);
  }
  td {
    padding: 12px; border-bottom: 1px solid var(--border);
  }
  tr:hover td { background: #f9fbff; }

  /* ============= PAGES ============= */
  .page { display: none; }
  .page.active { display: block; animation: fadein 0.25s ease; }
  @keyframes fadein { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

  /* ============= GOALS & TASKS ============= */
  .goal-item, .task-item {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 14px; border: 1px solid var(--border);
    border-radius: 10px; margin-bottom: 10px;
    background: #fff; transition: all 0.15s;
  }
  .goal-item:hover, .task-item:hover { border-color: var(--accent); }
  .goal-item.done, .task-item.done { background: #f4fbf7; border-color: #c4e6d1; }
  .goal-item.done .label-text, .task-item.done .label-text { text-decoration: line-through; color: var(--muted); }

  .checkbox {
    width: 22px; height: 22px; border-radius: 6px;
    border: 2px solid var(--border); display: flex; align-items: center;
    justify-content: center; cursor: pointer; flex-shrink: 0;
    margin-top: 2px;
    background: #fff;
  }
  .checkbox.checked {
    background: var(--accent); border-color: var(--accent); color: #fff;
  }
  .checkbox.checked::after { content: "✓"; font-weight: 700; }

  /* ============= ROLE CARDS ============= */
  .role-card {
    background: #fff; border-radius: 14px; padding: 20px;
    border: 1px solid var(--border); box-shadow: var(--shadow);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .role-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
  .role-icon {
    width: 48px; height: 48px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px; margin-bottom: 12px;
  }
  .role-name {
    font-size: 18px; font-weight: 800; color: var(--navy);
    margin-bottom: 4px;
  }
  .role-tagline {
    font-size: 13px; color: var(--muted); margin-bottom: 12px;
  }
  .role-tasks {
    margin: 0; padding-left: 18px; font-size: 13px; color: var(--text);
  }
  .role-tasks li { margin-bottom: 4px; }

  /* ============= RESOURCE GRID ============= */
  .res-card {
    background: #fff; border-radius: 12px; padding: 16px;
    border: 1px solid var(--border); transition: all 0.15s;
    cursor: pointer;
  }
  .res-card:hover { border-color: var(--accent); box-shadow: var(--shadow); }
  .res-icon { font-size: 24px; margin-bottom: 8px; }
  .res-title { font-weight: 700; color: var(--navy); margin-bottom: 4px; }
  .res-desc { font-size: 13px; color: var(--muted); margin-bottom: 6px; }
  .res-tag {
    font-size: 11px; padding: 2px 8px; border-radius: 6px;
    background: rgba(29,191,115,0.15); color: var(--accent-dark);
    font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;
    display: inline-block;
  }

  /* ============= MEETING ============= */
  .meeting-card {
    background: #fff; border-left: 4px solid var(--accent);
    padding: 16px 18px; border-radius: 10px;
    margin-bottom: 12px;
    box-shadow: var(--shadow);
  }
  .meeting-date { font-size: 12px; color: var(--muted); font-weight: 600; }
  .meeting-title { font-size: 16px; font-weight: 700; color: var(--navy); margin: 4px 0; }
  .meeting-notes { font-size: 14px; color: var(--text); margin-top: 8px; white-space: pre-wrap; }
  .meeting-attendees {
    font-size: 12px; color: var(--muted); margin-top: 6px;
    display: flex; flex-wrap: wrap; gap: 4px;
  }
  .chip {
    display: inline-block; font-size: 11px; font-weight: 600;
    padding: 2px 8px; border-radius: 10px;
    background: #eef2f9; color: var(--navy);
  }
  .chip-accent { background: rgba(29,191,115,0.15); color: var(--accent-dark); }
  .chip-gold { background: rgba(243,185,77,0.2); color: #9c7520; }
  .chip-red { background: #ffecec; color: var(--red); }

  /* ============= PROGRESS BAR ============= */
  .progress-bar {
    height: 8px; background: #eef2f9;
    border-radius: 4px; overflow: hidden; margin-top: 8px;
  }
  .progress-fill {
    height: 100%; background: linear-gradient(90deg, var(--accent), #0fa866);
    border-radius: 4px; transition: width 0.4s ease;
  }

  /* ============= AUTO-SAVE BADGE ============= */
  .save-badge {
    position: fixed; bottom: 20px; right: 20px;
    background: var(--accent); color: #fff;
    padding: 8px 14px; border-radius: 20px;
    font-size: 12px; font-weight: 600;
    box-shadow: var(--shadow-lg);
    opacity: 0; transform: translateY(20px);
    transition: all 0.3s;
    z-index: 200;
  }
  .save-badge.show { opacity: 1; transform: none; }

  /* ============= HERO ============= */
  .hero {
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-3) 100%);
    color: #fff; padding: 32px; border-radius: 16px;
    margin-bottom: 24px;
    position: relative; overflow: hidden;
  }
  .hero h1 { margin: 0 0 6px; font-size: 26px; }
  .hero p { margin: 0; opacity: 0.85; font-size: 15px; }
  .hero::after {
    content: ""; position: absolute; right: -40px; top: -40px;
    width: 200px; height: 200px; border-radius: 50%;
    background: radial-gradient(circle, rgba(29,191,115,0.3), transparent 70%);
  }

  /* ============= SMART PROMPT ============= */
  .smart-prompt {
    background: linear-gradient(135deg, rgba(29,191,115,0.1), rgba(29,191,115,0.02));
    border: 1px dashed var(--accent);
    padding: 14px 16px; border-radius: 12px;
    margin: 12px 0;
    font-size: 14px; color: var(--navy);
  }
  .smart-prompt .bulb { font-size: 18px; margin-right: 6px; }

  /* ============= PRESIDENT ============= */
  .president-badge {
    background: linear-gradient(135deg, var(--gold), #d99722);
    color: #fff; padding: 4px 10px; border-radius: 12px;
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.6px;
  }
  .lock-screen {
    text-align: center; padding: 60px 20px;
  }
  .lock-icon {
    font-size: 60px; margin-bottom: 16px;
  }
  .tab-bar {
    display: flex; gap: 4px; margin-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }
  .tab {
    padding: 10px 16px; font-weight: 600; font-size: 14px;
    color: var(--muted); cursor: pointer; border-bottom: 2px solid transparent;
    transition: all 0.15s;
  }
  .tab:hover { color: var(--navy); }
  .tab.active { color: var(--navy); border-bottom-color: var(--accent); }

  /* ============= COLLAPSIBLE ============= */
  details > summary {
    cursor: pointer; font-weight: 700; padding: 10px 0;
    color: var(--navy); list-style: none;
  }
  details > summary::before { content: "▸ "; color: var(--accent); }
  details[open] > summary::before { content: "▾ "; }
  details { border-bottom: 1px solid var(--border); padding-bottom: 8px; margin-bottom: 8px; }

  /* ============= QUESTION ============= */
  .q-card {
    background: #fff; padding: 14px 16px; border-radius: 10px;
    border: 1px solid var(--border); margin-bottom: 10px;
  }
  .q-text { font-weight: 600; color: var(--navy); margin-bottom: 4px; }
  .q-meta { font-size: 12px; color: var(--muted); margin-bottom: 8px; }
  .q-answer {
    background: #f4fbf7; border-left: 3px solid var(--accent);
    padding: 10px 12px; border-radius: 6px; font-size: 14px;
    color: var(--text); margin-top: 8px;
  }

  /* ============= RESPONSIVE ============= */
  @media (max-width: 780px) {
    .app { flex-direction: column; }
    .sidebar { width: 100%; height: auto; position: static; }
    .main { padding: 20px; max-width: 100%; }
  }
</style>
</head>
<body>

<!-- ============== WELCOME MODAL ============== -->
<div id="welcomeModal" class="modal-backdrop" style="display:none;">
  <div class="modal">
    <h2>👋 Welcome to Bull & Bear Investing Club</h2>
    <p class="subtitle">Invite teammates to collaborate on your project. Enter their emails below — you can add or remove as many as you need.</p>
    <div>
      <label>Your Name</label>
      <input id="welcomeName" placeholder="e.g., Alex Johnson" />
    </div>
    <div style="margin-top:14px;">
      <label>Project Name</label>
      <input id="welcomeProject" placeholder="e.g., Tech Sector Portfolio 2026" />
    </div>
    <div style="margin-top:14px;">
      <label>Invite Collaborators by Email</label>
      <div id="emailList">
        <div class="email-row">
          <input type="email" placeholder="teammate@school.edu" />
          <button class="icon-btn minus" onclick="removeEmail(this)">−</button>
        </div>
      </div>
      <button class="btn btn-secondary btn-sm" style="margin-top:8px;" onclick="addEmail()">＋ Add another email</button>
    </div>
    <div style="margin-top:22px; display:flex; justify-content:flex-end; gap:10px;">
      <button class="btn btn-ghost" onclick="skipWelcome()">Skip for now</button>
      <button class="btn btn-primary" onclick="saveWelcome()">Send invites & Get started →</button>
    </div>
  </div>
</div>

<!-- ============== APP ============== -->
<div class="app" id="app">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="brand">
      <div class="logo">📈</div>
      <div>Bull & Bear</div>
    </div>

    <div class="nav-section">Workspace</div>
    <div class="nav-item active" data-page="dashboard"><span class="icon">🏠</span> Dashboard</div>
    <div class="nav-item" data-page="investments"><span class="icon">💼</span> Investments</div>
    <div class="nav-item" data-page="meetings"><span class="icon">📝</span> Meeting Logs</div>
    <div class="nav-item" data-page="goals"><span class="icon">🎯</span> Goals</div>
    <div class="nav-item" data-page="tasks"><span class="icon">✅</span> Tasks</div>

    <div class="nav-section">Learn</div>
    <div class="nav-item" data-page="resources"><span class="icon">🔗</span> Resources</div>
    <div class="nav-item" data-page="roles"><span class="icon">👥</span> Roles</div>
    <div class="nav-item" data-page="help"><span class="icon">❓</span> Help & Jobs</div>

    <div class="nav-section">Leadership</div>
    <div class="nav-item" data-page="questions"><span class="icon">💬</span> Ask the President</div>
    <div class="nav-item" data-page="president"><span class="icon">🛡️</span> President / VP</div>
  </aside>

  <!-- MAIN -->
  <main class="main">

    <!-- ============== DASHBOARD ============== -->
    <section id="dashboard" class="page active">
      <div class="hero">
        <h1 id="heroGreet">Welcome back 👋</h1>
        <p>Track your investments, hit your goals, and grow smarter every meeting.</p>
      </div>

      <div class="grid grid-4" style="margin-bottom: 24px;">
        <div class="stat-card">
          <div class="stat-label">Portfolio Value</div>
          <div class="stat-value" id="statPortfolio">$0.00</div>
          <div class="stat-sub" id="statPortfolioChange">— vs. starting capital</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">vs. S&P 500</div>
          <div class="stat-value" id="statVsSPY">—</div>
          <div class="stat-sub">Club return minus benchmark</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Goals Completed</div>
          <div class="stat-value" id="statGoals">0/0</div>
          <div class="progress-bar"><div class="progress-fill" id="goalProgress" style="width:0%;"></div></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Meetings Logged</div>
          <div class="stat-value" id="statMeetings">0</div>
          <div class="stat-sub" id="statLastMeeting">No meetings yet</div>
        </div>
      </div>

      <div class="grid grid-2">
        <div class="card">
          <div class="card-title">📣 What to do next</div>
          <div id="smartPrompts"></div>
        </div>
        <div class="card">
          <div class="card-title">📅 Recent Meetings</div>
          <div id="dashMeetings"></div>
        </div>
      </div>
    </section>

    <!-- ============== INVESTMENTS ============== -->
    <section id="investments" class="page">
      <div class="page-header">
        <div>
          <div class="page-title">💼 Investment Portfolio</div>
          <div class="page-subtitle">Track your positions and compare performance to the S&P 500.</div>
        </div>
        <button class="btn btn-primary" onclick="toggleAddInvestment()">＋ Add Position</button>
      </div>

      <div class="grid grid-3" style="margin-bottom:20px;">
        <div class="stat-card">
          <div class="stat-label">Total Invested</div>
          <div class="stat-value" id="invTotalCost">$0.00</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Current Value</div>
          <div class="stat-value" id="invCurrent">$0.00</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Total Return</div>
          <div class="stat-value" id="invReturn">0.00%</div>
          <div class="stat-sub" id="invReturnDollar">$0.00</div>
        </div>
      </div>

      <div id="addInvestmentForm" class="card" style="display:none; margin-bottom:20px;">
        <div class="card-title">Add New Position</div>
        <div class="form-row">
          <div><label>Ticker</label><input id="newTicker" placeholder="AAPL" /></div>
          <div><label>Company Name</label><input id="newName" placeholder="Apple Inc." /></div>
          <div><label>Shares</label><input id="newShares" type="number" step="0.01" placeholder="10" /></div>
        </div>
        <div class="form-row">
          <div><label>Buy Price ($)</label><input id="newBuy" type="number" step="0.01" placeholder="180.50" /></div>
          <div><label>Current Price ($)</label><input id="newCurrent" type="number" step="0.01" placeholder="190.00" /></div>
          <div><label>Purchased On</label><input id="newDate" type="date" /></div>
        </div>
        <div style="display:flex; gap:10px; justify-content:flex-end;">
          <button class="btn btn-secondary" onclick="toggleAddInvestment()">Cancel</button>
          <button class="btn btn-primary" onclick="addInvestment()">Add Position</button>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Holdings</div>
        <div style="overflow-x:auto;">
          <table>
            <thead>
              <tr>
                <th>Ticker</th><th>Name</th><th>Shares</th><th>Buy $</th><th>Current $</th>
