  document.getElementById("statPortfolioChange").innerHTML = totalCost
    ? `<span class="${pct>=0?'stat-up':'stat-down'}">${pct>=0?"▲":"▼"} ${Math.abs(pct).toFixed(2)}%</span> from cost basis`
